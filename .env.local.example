# Public site URL (set after deploy, e.g. https://scout.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mobile app (oasis-mobile/) — run: pnpm mobile:env then pnpm mobile:start
# Uses production API + Expo tunnel so anyone can scan the QR (no same Wi‑Fi).
# Optional: EXPO_PUBLIC_MOBILE_API_MODE=local for same-Wi‑Fi dev against pnpm dev:lan

# Razorpay (India — card + UPI mandate subscriptions)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_PLAN_ID=plan_xxx

# Supabase (free tier — supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct DB URL — for pnpm db:migrate / catalog:migrate (NOT localhost unless supabase start).
# Supabase Dashboard → Settings → Database → Connection string → URI → **Session pooler**
# Replace [YOUR-PASSWORD] with your project DB password (Database → Reset password).
# Example host: aws-0-….pooler.supabase.com  (user often postgres.[project-ref])
SUPABASE_DB_URL=
# If DATABASE_URL is set, it overrides nothing — migrate prefers SUPABASE_DB_URL first.

# OCR_PADDLE_GPU=1
# OCR_PADDLE_GRAYSCALE=1
# OCR_PADDLE_DENOISE=1
# OCR_PADDLE_MAX_WIDTH=1600

# Catalog import: ~/Downloads/data.csv (product_variant_id, nutrition, ingredients, …)
#   pnpm warm-session -- --platform=zepto   # once, for BFF image fetch
#   pnpm catalog:sync
ZEPTO_CSV_PATH=
ZEPTO_STORE_ID=
ZEPTO_BFF_URL=https://bff-gateway.zepto.com/
ZEPTO_IMAGE_RPS=5

GROCERY_PLATFORM=zepto
GROCERY_RPS=3

# SCORING_ENGINE=v9         # now the default (cohort/relative/blend scoring)
# SCORING_RULE_VERSION=10   # bump when formula changes, then re-run `pnpm score -- --force`

# Apple Vision OCR (macOS) — see ocr-pipeline/README.md
OCR_BACKEND=vision
# OCR_PIPELINE_PYTHON=/path/to/oasis/ocr-pipeline/.venv/bin/python
# OCR_VISION_LEVEL=fast


