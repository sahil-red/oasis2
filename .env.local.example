# Public site URL (set after deploy, e.g. https://oasis-clone.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (free tier — supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Gemini — text fill for nutrition gaps (pnpm catalog:sync runs this automatically)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_RPM=10
GEMINI_RPD=500
GEMINI_TEXT_BATCH_SIZE=10

# Catalog import: ~/Downloads/data.csv (product_variant_id, nutrition, ingredients, …)
#   pnpm warm-session -- --platform=zepto   # once, for BFF image fetch
#   pnpm catalog:sync
ZEPTO_CSV_PATH=
ZEPTO_STORE_ID=
ZEPTO_BFF_URL=https://bff-gateway.zepto.com/
ZEPTO_IMAGE_RPS=5

GROCERY_PLATFORM=zepto
GROCERY_RPS=3

SCORING_RULE_VERSION=6
