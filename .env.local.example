# Public site URL (set after deploy, e.g. https://scout.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (free tier — supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct DB URL — for local scripts (pnpm catalog:migrate).
# Use **Session pooler** (IPv4), NOT "Direct connection" (IPv6-only on many networks).
SUPABASE_DB_URL=

# OCR_PADDLE_GPU=1
# OCR_PADDLE_GRAYSCALE=1
# OCR_PADDLE_DENOISE=1
# OCR_PADDLE_MAX_WIDTH=1600

# Catalog import: ~/Downloads/data.csv (product_variant_id, nutrition, ingredients, …)
#   pnpm warm-session -- --platform=zepto   # once, for BFF image fetch
#   pnpm catalog:sync
ZEPTO_CSV_PATH=
ZEPTO_STORE_ID=
ZEPTO_BFF_URL=https://bff-gateway.zepto.com/
ZEPTO_IMAGE_RPS=5

GROCERY_PLATFORM=zepto
GROCERY_RPS=3

SCORING_RULE_VERSION=6
