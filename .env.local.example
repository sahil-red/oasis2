# Public site URL (set after deploy, e.g. https://oasis-clone.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (free tier — supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
# Anon key: safe for browser; optional if you only use server-side reads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: server-only (Vercel env, never NEXT_PUBLIC). Used by /search + /product pages.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Gemini (free tier — aistudio.google.com)
GEMINI_API_KEY=
# Legacy single-model override (optional). OCR uses the pool below by default.
GEMINI_MODEL=gemini-3.1-flash-lite
# Dual Flash-Lite pool — round-robin + failover on 429 (free tier RPM per model):
#   gemini-3.1-flash-lite:15,gemini-2.5-flash-lite:10
GEMINI_MODELS=gemini-3.1-flash-lite:15,gemini-2.5-flash-lite:10

# Toggle LLM backend: "gemini" or "ollama"
LLM_BACKEND=gemini

# Per-model RPM fallback when only GEMINI_MODEL is set (pool ignores this)
GEMINI_RPM=10
GEMINI_RPD=500

# Optional: Ollama (if LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# OCR backend: "gemini" (multimodal, structured JSON, ~1500 RPD free) or
# "tesseract" (local, unlimited, lower quality on small/curved labels).
# "auto" tries gemini first, falls back to tesseract on rate-limit or error.
OCR_BACKEND=auto

# Cap how many OCR calls per script run (safety valve so a runaway loop
# doesn't burn the daily Gemini budget).
OCR_MAX_CALLS_PER_RUN=400

# Scraper knobs
GROCERY_PLATFORM=blinkit
GROCERY_RPS=3
GROCERY_BURST=2
SCRAPE_CONCURRENCY=4
SCRAPE_DETAIL_BATCH=500

# HTTP backend for scraper requests.
#   playwright (default when session has storage_state) → real Chromium
#                   page.evaluate(fetch) — only one that reliably passes
#                   Cloudflare bot manager for Indian quick-commerce.
#   curl        → system curl subprocess; works on less-aggressive origins.
#   fetch       → Node undici (documented to 403 against Cloudflare).
# Leave unset to let the adapter pick automatically (playwright if a
# storage_state is captured, curl otherwise).
# HTTP_BACKEND=

# Scoring engine
SCORING_RULE_VERSION=6
