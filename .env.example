# Supabase (required for catalog + search)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site
NEXT_PUBLIC_SITE_URL=

# DeepSeek — use separate keys so label batch jobs do not starve live search
DEEPSEEK_SEARCH_API_KEY=
DEEPSEEK_LABEL_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=

# Search V2 (LLM-first pipeline — SEARCH_V2_PLAN.md)
# NOTE: V2 is hardcoded ON in code; no flag needed in production.
# GROQ keys are used by CI evals (scripts/search-v2-regression) only — NOT live search.
GROQ_API_KEY=
GROQ_INTENT_MODEL=llama-3.3-70b-versatile
# Voyage AI (recommended for Hindi/Hinglish) — set VOYAGE_API_KEY or EMBEDDING_API_KEY + provider
# voyage-3.5: multilingual, 1024-dim, 200M tokens free (vs 50M for multilingual-2).
# IMPORTANT: add a payment method on Voyage to leave the free-trial cap (3 RPM / 10K TPM) —
# you still pay $0 within the 200M free tokens, but Tier-1 limits (2000 RPM / 8M TPM) are
# needed or the full index build will throttle for hours.
VOYAGE_API_KEY=
EMBEDDING_PROVIDER=voyage
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.voyageai.com/v1
EMBEDDING_MODEL=voyage-3.5
EMBEDDING_DIM=1024

# Cron — protects /api/cron/search-alerts (set in Vercel for daily alert sweep)
CRON_SECRET=

# Razorpay (Scout Plus billing) — ALL FIVE required in Vercel once billing is live.
# RAZORPAY_WEBHOOK_SECRET is critical: webhooks fail CLOSED without it, so paid
# users would never be upgraded to Plus. Also register the webhook URL
# (https://YOUR-APP/api/billing/webhook) in the Razorpay dashboard.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_PLAN_ID_YEARLY=
RAZORPAY_WEBHOOK_SECRET=

# Error monitoring (Sentry) — optional but strongly recommended for launch.
# Create a free Sentry project (Next.js) and paste the same DSN into both.
# Leave empty to disable entirely (zero overhead).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Anonymous search gate — optional dedicated HMAC secret for the signed counter
# cookie. Falls back to a hash of SUPABASE_SERVICE_ROLE_KEY when unset.
ANON_GATE_SECRET=
