{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/lib/search/*": ["../lib/search/*"],
      "@/lib/diet/*": ["../lib/diet/*"],
      "@/lib/goals/*": ["../lib/goals/*"],
      "@/lib/products/*": ["../lib/products/*"],
      "@/lib/scoring/*": ["../lib/scoring/*"]
    }
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "src/**/*.ts", "src/**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
