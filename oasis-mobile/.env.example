# Same Supabase project + API as the web app — do not create a second DB.
# From repo root: pnpm mobile:env  (default: production API for worldwide Expo QR)
#
# Share with anyone: pnpm mobile:start  (Expo tunnel — no same Wi‑Fi needed)
#
# Same-Wi‑Fi local API only (root .env.local):
#   EXPO_PUBLIC_MOBILE_API_MODE=local
EXPO_PUBLIC_API_URL=https://oasis-phi-one.vercel.app
EXPO_PUBLIC_MOBILE_API_MODE=production
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
